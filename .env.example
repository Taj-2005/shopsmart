# Copy this file to .env before running docker compose up
# docker compose automatically loads variables from .env

POSTGRES_USER=notesuser
POSTGRES_PASSWORD=notespass
POSTGRES_DB=notesdb

# Constructed from the variables above.
# "db" is the service name — Docker resolves it to the container's IP.
DATABASE_URL=postgresql://notesuser:notespass@db:5432/notesdb

REDIS_HOST=redis
